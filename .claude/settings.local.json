{
  "permissions": {
    "allow": [
      "Bash(npm install:*)",
      "Bash(timeout 5 node src/app.js)",
      "Bash(taskkill /F /IM node.exe)",
      "Bash(netstat -ano)",
      "Bash(findstr \":3000\")",
      "Bash(findstr \"LISTENING\")",
      "Bash(taskkill /PID 22564 /F)",
      "Bash(cmd /c \"taskkill /PID 22564 /F\")",
      "Bash(cmd /c \"taskkill /PID 22564 /F && echo OK\")",
      "Bash(powershell -Command \"Stop-Process -Id 22564 -Force -ErrorAction SilentlyContinue; Write-Host 'Done'\")",
      "Bash(powershell -Command \"netstat -ano | Select-String ':3000.*LISTENING'\")"
    ]
  }
}
